# Configuration for Personal Finance Assistant

# LLM Settings
LLM_PROVIDER=openai  # Options: openai, google, anthropic
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# API Keys (Never commit these!)
TAVILY_API_KEY=your_tavily_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here
# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Specify OpenAI model versions
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
GOOGLE_API_KEY=your_google_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Vector Store Configuration
VECTOR_STORE=chroma  # Options: chroma, pinecone, faiss
CHROMA_PERSIST_DIR=./data/chroma_db

# Market Data
MARKET_DATA_PROVIDER=yfinance  # Options: yfinance, alpha_vantage
CACHE_TTL_HOURS=1

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
MAX_CONVERSATION_LENGTH=50

# UI Settings
STREAMLIT_THEME=light
STREAMLIT_PORT=8501

# MCP Server (Optional)
MCP_ENABLED=false
MCP_PORT=8000
