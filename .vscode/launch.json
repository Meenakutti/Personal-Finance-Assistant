{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: Personal Finance Assistant",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/ui/app.py",
        "--server.port=8502",
        "--server.headless=true"
      ],
      "python": "${workspaceFolder}/.venv3.12/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "env": {},
      "console": "integratedTerminal",
      "justMyCode": true,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local URL: (http://localhost:\\d+)",
        "uriFormat": "%s"
      }
    }
  ]
}
